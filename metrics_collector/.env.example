# For local run (go run ./cmd/quotes-collector):
COLLECTOR_DEVICE_PATH=/dev/urandom

# For docker-compose device mapping:
COLLECTOR_HOST_DEVICE=/dev/vtp_moex0

COLLECTOR_DEVICE_OPEN_RETRY=1s
COLLECTOR_INPUT_MODE=random
COLLECTOR_PUBLISH_DELAY=100ms
COLLECTOR_READ_BUFFER_BYTES=4096
COLLECTOR_VERIFY_CRC=true
COLLECTOR_LOG_INTERVAL=10s
COLLECTOR_STRICT_SINKS=false
COLLECTOR_STDOUT_ENABLED=true

VALKEY_ENABLED=true
VALKEY_ADDRESS=127.0.0.1:6379
VALKEY_CHANNEL=quotes.ticks
VALKEY_USERNAME=
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_TIMEOUT=3s

CLICKHOUSE_ENABLED=true
CLICKHOUSE_ENDPOINT=http://127.0.0.1:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_TABLE=raw_ticks
CLICKHOUSE_USERNAME=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_TIMEOUT=5s
CLICKHOUSE_AUTO_CREATE_TABLE=true
